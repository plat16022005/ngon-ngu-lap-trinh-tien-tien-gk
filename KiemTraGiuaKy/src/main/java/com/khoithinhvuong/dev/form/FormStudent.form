<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.khoithinhvuong.dev.form.FormStudent">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="10" width="575" height="410"/>
    </constraints>
    <properties>
      <preferredSize width="150" height="257"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="bbb5d" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="69479" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-13627120"/>
              <font size="24" style="1"/>
              <text value="STUDENT DASHBOARD"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="b6379" binding="menuPanel" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="West"/>
        <properties>
          <enabled value="true"/>
        </properties>
        <border type="none">
          <font/>
          <title-color color="-2104859"/>
        </border>
        <children>
          <component id="66d2c" class="javax.swing.JButton" binding="myCourseButton" default-binding="true">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="My Course"/>
            </properties>
          </component>
          <component id="c7042" class="javax.swing.JButton" binding="paymentInvoiceButton" default-binding="true">
